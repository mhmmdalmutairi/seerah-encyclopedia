{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Seerah Encyclopedia — Entity Card Schema (v3: Round 10 — Methodological Review)",
  "description": "بطاقة كيان متخصص في خدمة السيرة النبوية. الإصدار 3 (الجولة 10) يُضيف: حقول مشروعية (project_alignment, methodology_school, trajectory, target_audience, output_volume_yearly)، أنواع كيانات جديدة (key_publication, unaffiliated_scholar, school_of_thought, audience_segment, documented_gap, manuscript_holding)، وعلاقات موسَّعة. التوصيفات الخاصة بمشروع الشيخ سعد البخيت في ملفّ منفصل: data/project_annotations.json.",
  "type": "object",
  "required": [
    "id", "round", "name_ar", "type", "type_group",
    "country", "region", "verification", "inclusion_tier", "sources"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^(ARB|LEV|MAG|TUR|NAM|WEST|GLB)-\\d{3,4}$",
      "description": "بادئة إقليمية + رقم تسلسلي. GLB للكيانات العابرة للأقاليم. 4 خانات تتيح التوسعة."
    },
    "round": {
      "type": "string",
      "enum": ["01", "02", "03", "04", "05", "06", "08a", "08b", "08c", "08d", "08e", "08f", "08g", "08h", "08k", "08l", "08m", "08t", "08y", "09a", "10a", "10b", "10c"]
    },
    "name_ar": { "type": "string" },
    "name_en": { "type": "string" },
    "aka": { "type": "array", "items": { "type": "string" } },

    "type_group": {
      "type": "string",
      "enum": [
        "research_education",
        "publishing_knowledge",
        "media_audience",
        "museums_culture",
        "institutional_infra",
        "individual_actors"
      ],
      "description": "المجموعة الرئيسة (6). كل type يُشتق منها."
    },

    "type": {
      "type": "string",
      "enum": [
        "university_center", "university_department", "academic_chair",
        "research_center", "foundation_waqf", "encyclopedia_project",
        "publisher", "journal", "popular_magazine", "library_archive",
        "digital_platform", "production_studio", "tv_channel",
        "podcast_institutional", "mobile_app", "film_or_series",
        "museum", "mosque_program", "islamic_center",
        "award", "grant", "conference_series",
        "ministry_program", "royal_initiative",
        "individual_researcher", "popular_writer",
        "digital_creator", "reference_thinker",
        "key_publication", "unaffiliated_scholar", "school_of_thought",
        "audience_segment", "documented_gap", "manuscript_holding"
      ]
    },

    "country": { "type": "string", "description": "ISO 3166-1 alpha-2" },
    "city_ar": { "type": "string" },
    "region": {
      "type": "string",
      "enum": ["arabia", "levant_iraq_nile", "maghreb", "turkey", "non_arab_muslim", "western", "global"]
    },

    "founded": { "type": ["integer", "null"] },
    "founded_decade": { "type": ["string", "null"] },
    "status": {
      "type": "string",
      "enum": ["active", "dormant", "suspended", "closed", "archived_digital"]
    },
    "status_note_ar": { "type": "string" },

    "scale": {
      "type": "string",
      "enum": ["local", "national", "regional", "international"]
    },

    "output_types": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "journal", "books", "conference", "lectures",
          "podcast_episode", "video", "documentary_film", "tv_series",
          "exhibition", "database", "encyclopedia", "manuscripts",
          "courses", "fatwa", "translation",
          "mobile_app_output", "educational_game", "khutbah_archive"
        ]
      }
    },

    "languages": {
      "type": "array",
      "items": { "type": "string" }
    },

    "subjects_category": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "classical_corpus",
          "geography_space",
          "prophetic_demography",
          "auxiliary_sciences",
          "methodology_critique",
          "application_outreach",
          "applied_jurisprudence"
        ]
      },
      "description": "حقل مشتق: المجموعات الموضوعية المغطّاة (يُحسب تلقائياً من subjects)"
    },

    "subjects": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "seerah_general", "maghazi", "shamail", "mawlid",
          "dalail_nubuwwa", "khasais_nabawiyyah",
          "seerah_geography", "makkah_studies", "madinah_studies",
          "early_islam", "rashidun",
          "tabaqat_companions", "women_in_seerah", "wufud_diplomacy",
          "ahlulbayt", "ahl_al_sunna", "family_household",
          "manuscripts", "hadith_sciences", "sources_critique", "historiography",
          "biography_methodology", "orientalism_critique", "comparative_religion",
          "sufism_seerah", "seerah_pedagogy", "youth_outreach",
          "digital_seerah", "tarjamah",
          "medicine_prophetic", "seerah_in_quran"
        ],
        "description": "31 موضوعاً متاحاً. mawlid أُضيف في الإصدار 3 (الجولة 10) لتوافق البيانات الفعلية. أي موضوع غير في القائمة → يُضاف للـ schema قبل إدراجه."
      }
    },

    "key_figures": {
      "type": "array",
      "items": { "type": "string" }
    },
    "parent_organization_ar": { "type": "string" },
    "funding_type": {
      "type": "string",
      "enum": ["state", "religious_authority", "waqf", "private", "academic_host", "mixed", "unknown"]
    },

    "explicit_relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target", "type"],
        "properties": {
          "target": { "type": "string" },
          "type": {
            "type": "string",
            "enum": [
              "parent_of", "child_of", "partner", "successor_of", "predecessor_of",
              "member_of_network", "publisher_of", "cited_in", "translated_by",
              "spawned_from", "influenced_by", "mentored_by", "cites", "cited_by",
              "competes_with", "complements"
            ]
          },
          "note_ar": { "type": "string" }
        }
      },
      "description": "العلاقات الصريحة بين الكيانات. أُضيفت في الإصدار 3 (الجولة 10): spawned_from, influenced_by, mentored_by, cites, cited_by, competes_with, complements."
    },

    "methodology_school": {
      "type": "string",
      "enum": [
        "classical_sunni",
        "albani_critical",
        "salim_al_hilali",
        "sallaby_modernist",
        "turkish_modernist",
        "muhammadia_andalusi",
        "shia_imami",
        "shia_zaydi",
        "sufi_traditionalist",
        "western_critical",
        "western_rehabilitative",
        "western_empirical_linguistic",
        "mixed_eclectic",
        "popular_unspecified",
        "unknown"
      ],
      "description": "التيار المنهجي للكيان في تَناول السيرة. أُضيف في الإصدار 3 (الجولة 10) لخدمة التحليل المقارن."
    },

    "trajectory": {
      "type": "string",
      "enum": ["growing", "stable", "declining", "peaked_then_stable", "dormant_revivable", "ended"],
      "description": "مسار الكيان: صاعد / مستقر / متراجع / بلغ ذروته ثم استقرّ / خامد قابل للإحياء / منتهٍ. أُضيف في الإصدار 3."
    },

    "target_audience": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["specialist", "intellectual", "general", "child", "youth", "woman", "convert", "non_muslim", "policy_maker", "educator"]
      },
      "description": "الجمهور المستهدَف. متعدّد القيم. أُضيف في الإصدار 3 لتحليل التموضع التنافسي."
    },

    "output_volume_yearly": {
      "type": "string",
      "enum": ["very_high", "high", "medium", "low", "very_low", "irregular", "unknown"],
      "description": "حجم الإنتاج السنوي (مقدّر): very_high>20 منتجاً/سنة، high 10-20، medium 5-10، low 1-5، very_low <1. أُضيف في الإصدار 3."
    },

    "quality_signal": {
      "type": "object",
      "properties": {
        "scholarly_rigor": { "type": "integer", "minimum": 1, "maximum": 5, "description": "1=شعبي، 5=أكاديمي صارم" },
        "audience_reach": { "type": "string", "enum": ["small", "medium", "large", "massive"] },
        "peer_recognition": { "type": "string", "enum": ["established", "emerging", "contested", "isolated", "unknown"] }
      },
      "description": "إشارات الجودة والأثر. أُضيفت في الإصدار 3."
    },

    "project_alignment": {
      "type": "string",
      "enum": [
        "directly_aligned",
        "partially_aligned",
        "methodology_reference",
        "audience_reference",
        "potential_partner",
        "competitor",
        "excluded_permanent"
      ],
      "description": "علاقة الكيان بمشروع الشيخ سعد البخيت. مفصول عن الموسوعة العامة. التفاصيل في data/project_annotations.json. directly_aligned هو الافتراضي للـ233 الحاليين."
    },

    "description_ar": { "type": "string" },
    "notes_ar": { "type": "string" },

    "verification": {
      "type": "string",
      "enum": ["field_verified", "desk_verified", "needs_verification", "unverifiable"]
    },
    "inclusion_tier": {
      "type": "string",
      "enum": ["core", "borderline", "below_threshold"]
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["round_file"],
        "properties": {
          "round_file": { "type": "string" },
          "anchor": { "type": "string" }
        }
      }
    },
    "url": { "type": "string", "format": "uri" }
  }
}
